
<section class="page-header"><div><h1><%= mode === 'agents' ? 'Agents' : 'Users' %> for <%= entity.name %></h1><p class="muted"><%= entity.path %></p></div><a class="button-link secondary" href="<%= basePath %>/entities">Back to Entities</a></section>
<section class="card"><div class="table-wrap"><table><thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Membership</th></tr></thead><tbody><% memberships.forEach((membership) => { %><tr><td><%= membership.userId.name %></td><td><%= membership.userId.email %></td><td><span class="pill"><%= membership.userId.role %></span></td><td><%= membership.isPrimary ? 'Primary entity' : 'Assigned entity' %></td></tr><% }) %><% if (!memberships.length) { %><tr><td colspan="4" class="muted">No <%= mode === 'agents' ? 'agents' : 'users' %> found for this entity.</td></tr><% } %></tbody></table></div></section>
