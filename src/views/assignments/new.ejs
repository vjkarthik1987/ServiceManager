
<section class="page-header"><div><h1>Assign agent to entity</h1><p class="muted">Grant an agent access to one or more client entities with a cleaner form layout.</p></div><a class="button-link secondary" href="<%= basePath %>/users">Back to Users</a></section>
<section class="card form-card"><form method="post" action="<%= basePath %>/assignments/agent" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="form-grid"><label><span>Agent</span><select name="agentUserId" required><option value="">Select agent</option><% agents.forEach((agent) => { %><option value="<%= agent._id %>"><%= agent.name %> · <%= agent.email %></option><% }) %></select></label><label><span>Entity</span><select name="entityId" required><option value="">Select entity</option><% entities.forEach((entity) => { %><option value="<%= entity._id %>"><%= entity.path %> (<%= entity.type %>)</option><% }) %></select></label></div><div class="form-actions right wrap-actions"><a class="button-link secondary" href="<%= basePath %>/users">Back to Users</a><button class="btn" type="submit">Assign agent</button></div></form></section>
