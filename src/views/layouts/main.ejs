
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="<%= csrfToken %>" />
    <title><%= title ? `${title} | ${tenant ? tenant.name : 'ESOP'} Workspace` : `${tenant ? tenant.name : 'ESOP'} Workspace` %></title>
    <link rel="icon" type="image/svg+xml" href="/images/favicon-esop.svg" />
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <% const roleLabel = currentUser ? (currentUser.role === 'client' ? 'CLIENT_USER' : currentUser.role.toUpperCase()) : ''; %>
    <% const navItems = [
      { href: currentUser && currentUser.role === 'client' ? `${basePath}/client/dashboard` : `${basePath}/dashboard`, label: currentUser && currentUser.role === 'client' ? 'Client Dashboard' : 'Dashboard', show: !!currentUser },
      { href: currentUser && currentUser.role === 'client' ? `${basePath}/client/issues` : `${basePath}/tickets`, label: currentUser && currentUser.role === 'client' ? 'My Issues' : 'Issues', show: !!currentUser },
      { href: `${basePath}/agent/workspace`, label: 'Agent Workspace', show: currentUser && ['agent', 'superadmin'].includes(currentUser.role) },
      { href: `${basePath}/entities`, label: 'Entities', show: currentUser && ['superadmin', 'client'].includes(currentUser.role) },
      { href: `${basePath}/users`, label: 'Users', show: currentUser && ['superadmin', 'client'].includes(currentUser.role) },
      { href: `${basePath}/assignments/new`, label: 'Agents', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/console`, label: 'Admin Console', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/integrations/jira`, label: 'Jira', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/routing-rules`, label: 'Routing Rules', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/status-mappings`, label: 'Status Mapping', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/sla-policies`, label: 'SLA Policies', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/products`, label: 'Products', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/notifications`, label: `Notifications${unreadNotificationCount ? ' (' + unreadNotificationCount + ')' : ''}`, show: currentUser && !!currentUser },
      { href: `${basePath}/admin/notification-preferences`, label: 'Notification Prefs', show: currentUser && !!currentUser },
      { href: `${basePath}/users/account/change-password`, label: 'Change Password', show: currentUser && !!currentUser },
      { href: `${basePath}/admin/saved-views`, label: 'Saved Views', show: currentUser && !!currentUser },
      { href: `${basePath}/admin/workflows`, label: 'Workflow', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/audit`, label: 'Audit Explorer', show: currentUser && currentUser.role === 'superadmin' },
      { href: `${basePath}/admin/ops`, label: 'Ops Console', show: currentUser && currentUser.role === 'superadmin' }
    ]; %>

    <% if (currentUser) { %>
      <button class="mobile-menu-button" type="button" onclick="document.body.classList.toggle('sidebar-open')">☰ Workspace</button>
      <div class="mobile-backdrop" onclick="document.body.classList.remove('sidebar-open')"></div>
      <aside class="sidebar">
        <div class="sidebar-header">
          <a class="brand" href="<%= basePath %>/dashboard">ESOP</a>
          <div class="workspace-chip"><span class="dot"></span><%= tenant ? tenant.name : 'Workspace' %></div>
          <div class="muted small"><%= tenant ? `/${tenant.slug}` : '' %></div>
        </div>
        <div class="sidebar-top-actions">
          <form method="post" action="<%= basePath %>/logout" class="inline-form logout-form top-logout-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="button-link logout-dark" type="submit">Logout</button>
          </form>
        </div>
        <nav class="sidebar-nav">
          <% navItems.filter((item) => item.show).forEach((item) => { %>
            <a class="nav-link <%= currentPath && currentPath.startsWith(item.href) ? 'active' : '' %>" href="<%= item.href %>"><%= item.label %></a>
          <% }) %>
        </nav>
        <div class="sidebar-footer"><span class="pill"><%= currentUser.name %> · <%= roleLabel %></span></div>
      </aside>
    <% } %>

    <main class="main-shell <%= currentUser ? 'with-sidebar' : '' %>">
      <div class="container page">
        <% if (success) { %>
          <div class="alert success" data-alert><span><%= success %></span><button type="button" class="alert-close" data-close-alert>×</button></div>
        <% } %>
        <% if (error) { %>
          <div class="alert error" data-alert><span><%= error %></span><button type="button" class="alert-close" data-close-alert>×</button></div>
        <% } %>
        <%- body %>
        <footer class="main-footer">Built for multi-tenant service operations · Secure attachments · Tenant-aware workspace routes · <%= appVersion || 'v30.0.0' %></footer>
      </div>
    </main>

    <script>
      (function () {
        function formatSize(size) {
          var bytes = Number(size || 0);
          if (bytes >= 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
          if (bytes >= 1024) return Math.max(1, Math.round(bytes / 1024)) + ' KB';
          return bytes + ' B';
        }
        document.querySelectorAll('[data-close-alert]').forEach(function (button) {
          button.addEventListener('click', function () {
            var alert = button.closest('[data-alert]');
            if (alert) alert.remove();
          });
        });
        document.querySelectorAll('[data-file-preview-input]').forEach(function (input) {
          input.addEventListener('change', function () {
            var key = input.getAttribute('data-file-preview-input');
            var list = document.querySelector('[data-file-preview-list="' + key + '"]');
            if (!list) return;
            list.innerHTML = '';
            var files = Array.from(input.files || []);
            if (!files.length) { list.hidden = true; return; }
            list.hidden = false;
            files.forEach(function (file) {
              var item = document.createElement('div'); item.className = 'selected-file-item';
              var preview = document.createElement('div'); preview.className = 'selected-file-preview';
              if ((file.type || '').indexOf('image/') === 0) {
                var img = document.createElement('img'); img.className = 'attachment-thumb'; img.alt = file.name; img.src = URL.createObjectURL(file); img.onload = function () { URL.revokeObjectURL(img.src); }; preview.appendChild(img);
              } else if (file.type === 'application/pdf' || /\.pdf$/i.test(file.name)) {
                var pdf = document.createElement('div'); pdf.className = 'attachment-pdf-tile'; pdf.innerHTML = '<span>PDF</span>'; preview.appendChild(pdf);
              } else {
                preview.innerHTML = '<div class="attachment-icon">📎</div>';
              }
              var meta = document.createElement('div'); meta.className = 'attachment-body';
              var strong = document.createElement('strong'); strong.textContent = file.name;
              var small = document.createElement('span'); small.className = 'muted small'; small.textContent = (file.type || 'unknown') + ' • ' + formatSize(file.size);
              meta.appendChild(strong); meta.appendChild(small); item.appendChild(preview); item.appendChild(meta); list.appendChild(item);
            });
          });
        });
      })();
    </script>
  </body>
</html>
