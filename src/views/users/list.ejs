
<section class="page-header">
  <div><h1>Users</h1><p class="muted">Visible users are restricted to your administrative scope.</p></div>
  <div class="header-actions wrap-actions"><a class="button-link secondary" href="<%= basePath %>/users/export<%= buildQueryString(filters) %>">Download Excel</a><a class="button-link" href="<%= basePath %>/users/new?role=client">Create User</a></div>
</section>
<form method="get" action="<%= basePath %>/users" class="card filters-form stack"><div class="grid-two"><label><span>Search</span><input type="text" name="q" value="<%= filters.q %>" placeholder="Name, email, entity" /></label><label><span>Role</span><select name="role"><option value="">All roles</option><option value="superadmin" <%= filters.role === 'superadmin' ? 'selected' : '' %>>Superadmin</option><option value="agent" <%= filters.role === 'agent' ? 'selected' : '' %>>Agent</option><option value="client" <%= filters.role === 'client' ? 'selected' : '' %>>Client User</option></select></label></div><div class="form-actions right wrap-actions"><a class="button-link secondary" href="<%= basePath %>/users">Reset</a><button type="submit">Apply Filters</button></div></form>
<section class="card"><% if (!users.length) { %><p class="muted">No users available.</p><% } else { %><div class="table-wrap"><table><thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Entity Access</th></tr></thead><tbody><% users.forEach(({ user, memberships }) => { %><tr><td><% if (currentUser.role === 'superadmin') { %><a href="<%= basePath %>/admin/users/<%= user._id %>"><%= user.name %></a><% } else { %><%= user.name %><% } %></td><td><%= user.email %></td><td><span class="pill"><%= user.role === 'client' ? 'CLIENT_USER' : user.role.toUpperCase() %></span></td><td><%= memberships.length ? memberships.map((m) => `${m.entityId ? m.entityId.path : 'Unknown'}${m.isPrimary ? ' (primary)' : ''}`).join(', ') : 'All entities' %></td></tr><% }) %></tbody></table></div><%- include('../partials/pagination', { pager, baseUrl: `${basePath}/users`, filters, buildQueryString }) %><% } %></section>
