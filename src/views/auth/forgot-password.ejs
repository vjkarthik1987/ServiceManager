<section class="auth-shell">
  <div class="auth-card">
    <div class="section-kicker">Forgot password</div>
    <h1><%= tenant ? tenant.name : 'ESOP' %></h1>
    <p class="muted">Enter your workspace email address. If it exists, we will send a reset link.</p>
    <form method="post" action="<%= basePath %>/forgot-password" class="stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label><span>Email</span><input type="email" name="email" required autofocus /></label>
      <button type="submit">Send reset link</button>
    </form>
    <p class="muted small"><a href="<%= basePath %>/login">Back to login</a></p>
  </div>
</section>
