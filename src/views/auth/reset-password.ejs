<section class="auth-shell">
  <div class="auth-card">
    <div class="section-kicker">Reset password</div>
    <h1><%= tenant ? tenant.name : 'ESOP' %></h1>
    <p class="muted">Choose a new password for your workspace account.</p>
    <form method="post" action="<%= basePath %>/reset-password/<%= token %>" class="stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label><span>New password</span><input type="password" name="newPassword" minlength="8" required autofocus /></label>
      <label><span>Confirm new password</span><input type="password" name="confirmPassword" minlength="8" required /></label>
      <button type="submit">Reset password</button>
    </form>
    <p class="muted small"><a href="<%= basePath %>/login">Back to login</a></p>
  </div>
</section>
